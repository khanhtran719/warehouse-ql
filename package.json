{
  "name": "warehouse-ql",
  "private": true,
  "version": "0.1.0",
  "description": "Warehouse CMS with NestJS API and React admin UI",
  "scripts": {
    "dev": "pnpm --parallel --filter @warehouse/api --filter @warehouse/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "docker:build": "scripts/build-docker.sh build",
    "docker:up": "scripts/build-docker.sh up",
    "docker:migrate": "scripts/build-docker.sh migrate",
    "docker:seed": "scripts/build-docker.sh seed",
    "docker:down": "scripts/build-docker.sh down"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.33.0"
}
