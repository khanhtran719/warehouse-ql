{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5",
  "default_agent": "build",
  "shell": "/bin/zsh",
  "share": "disabled",
  "instructions": [".ai/AGENTS.md", ".ai/PROJECTS.md", ".ai/MEMORIES.md", ".ai/USER.md"],
  "skills": {
    "paths": ["~/.agents/skills", "~/.claude/skills", ".opencode/skills", "~/.hermes/skills"]
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "skill": "allow",
    "webfetch": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "pnpm build*": "allow",
      "pnpm test*": "allow",
      "pnpm lint*": "allow",
      "pnpm --filter @warehouse/api build*": "allow",
      "pnpm --filter @warehouse/api test*": "allow",
      "pnpm --filter @warehouse/api lint*": "allow",
      "pnpm --filter @warehouse/web build*": "allow",
      "pnpm --filter @warehouse/web test*": "allow",
      "pnpm --filter @warehouse/web lint*": "allow",
      "docker compose config*": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/var/folders/v7/ls8ghvtn3vj10mny24fbr6800000gn/T/opencode/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 51200
  },
  "compaction": {
    "auto": true,
    "tail_turns": 6
  },
  "lsp": true,
  "formatter": true,
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "coverage/**",
      "apps/web/dist/**",
      "apps/api/dist/**"
    ]
  }
}
